# Optional: server port (default 3000)
# PORT=3001

# Production: comma-separated origins allowed to call the API (CORS), e.g. your Vercel site
# FRONTEND_ORIGIN=https://your-app.vercel.app

# Optional: OpenAI for coach narration, similar-title paragraph, and per-book reading companion
# (discussion questions, read-alikes, “If you liked…”). Replies are cached in SQLite by book + mode + content hash.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
